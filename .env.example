# ── Infrastructure ─────────────────────────────────────────────────────────────
KC_ADMIN_USER=admin
KC_ADMIN_PASSWORD=

POSTGRES_USER=raguser
POSTGRES_PASSWORD=

# ── AWS ────────────────────────────────────────────────────────────────────────
# Tip: if you use `aws configure`, these are already in your shell — no need to set them here.
# Only needed if you want to override or use a different profile in docker-compose.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=          # leave blank unless using temporary/SSO credentials

AWS_REGION=eu-west-1
BEDROCK_REGION=eu-west-1    # must support claude-haiku-4-5 and Titan V2
COMPREHEND_REGION=eu-central-1

S3_BUCKET_NAME=             # the bucket used for document uploads (must exist in AWS)

# ── Observability ───────────────────────────────────────────────────────────────
GF_ADMIN_USER=admin
GF_ADMIN_PASSWORD=

# ── Keycloak test users (for developer reference only — passwords are hashed in rag-realm.json) ──
ALICE_PASSWORD=alice123     # roles: executive, admin
BOB_PASSWORD=bob123         # roles: hr, admin
CAROL_PASSWORD=carol123     # roles: manager, admin
DAVE_PASSWORD=dave123       # roles: employee
