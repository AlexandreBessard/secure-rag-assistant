{
  "id": null,
  "title": "RAG — LLM Cost",
  "uid": "rag-llm-cost",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-24h", "to": "now" },
  "tags": ["rag", "cost"],
  "templating": {
    "list": [
      {
        "type": "datasource",
        "name": "datasource",
        "label": "Datasource",
        "query": "prometheus",
        "current": { "text": "Prometheus", "value": "Prometheus" },
        "hide": 0
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Total Cost",
      "description": "Input + output token cost for the selected time range (Claude Haiku 4.5 on Bedrock)",
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "(\n  (sum(increase(gen_ai_client_token_usage_total{gen_ai_token_type=\"input\"}[$__range])) or vector(0)) * 0.0000008\n)\n+\n(\n  (sum(increase(gen_ai_client_token_usage_total{gen_ai_token_type=\"output\"}[$__range])) or vector(0)) * 0.000004\n)",
          "legendFormat": "Total"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 6,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.01 },
              { "color": "red", "value": 0.1 }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Input Token Cost",
      "description": "$0.80 per 1M tokens",
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "(sum(increase(gen_ai_client_token_usage_total{gen_ai_token_type=\"input\"}[$__range])) or vector(0)) * 0.0000008",
          "legendFormat": "Input"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 6,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Output Token Cost",
      "description": "$4.00 per 1M tokens",
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "(sum(increase(gen_ai_client_token_usage_total{gen_ai_token_type=\"output\"}[$__range])) or vector(0)) * 0.000004",
          "legendFormat": "Output"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 6,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "orange", "value": null }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Cost Rate (USD / hour)",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "(\n  sum(rate(gen_ai_client_token_usage_total{gen_ai_token_type=\"input\"}[$__rate_interval])) * 0.0000008\n  +\n  sum(rate(gen_ai_client_token_usage_total{gen_ai_token_type=\"output\"}[$__rate_interval])) * 0.000004\n) * 3600",
          "legendFormat": "Total cost/hour"
        },
        {
          "expr": "sum(rate(gen_ai_client_token_usage_total{gen_ai_token_type=\"input\"}[$__rate_interval])) * 0.0000008 * 3600",
          "legendFormat": "Input cost/hour"
        },
        {
          "expr": "sum(rate(gen_ai_client_token_usage_total{gen_ai_token_type=\"output\"}[$__rate_interval])) * 0.000004 * 3600",
          "legendFormat": "Output cost/hour"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 6,
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          }
        }
      }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Total Input Tokens",
      "gridPos": { "h": 4, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum(increase(gen_ai_client_token_usage_total{gen_ai_token_type=\"input\"}[$__range])) or vector(0)",
          "legendFormat": "Input tokens"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "none",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0
        }
      }
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Total Output Tokens",
      "gridPos": { "h": 4, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum(increase(gen_ai_client_token_usage_total{gen_ai_token_type=\"output\"}[$__range])) or vector(0)",
          "legendFormat": "Output tokens"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "none",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0
        }
      }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Token Usage Rate (tokens / min)",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum by (gen_ai_token_type) (rate(gen_ai_client_token_usage_total[$__rate_interval])) * 60",
          "legendFormat": "{{gen_ai_token_type}}"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 1,
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          }
        }
      }
    }
  ]
}
